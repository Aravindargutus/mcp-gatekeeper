# Required for Gate 4 (AI Semantic Evaluation)
# Get your key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: For OpenAI-compatible provider (Groq, Ollama, etc.)
# OPENAI_API_KEY=your-openai-api-key-here

# Optional: Override default config path
MCPQA_CONFIG=./configs/default.yaml

# Optional: Report output directory
MCPQA_REPORT_DIR=./reports
