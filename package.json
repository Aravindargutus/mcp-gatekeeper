{
  "name": "mcpqa",
  "version": "0.1.0",
  "description": "MCP QA Framework — 5-Gated Pipeline for validating MCP servers",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mcpqa": "./dist/cli.js",
    "mcpqa-server": "./dist/mcp-server.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "mcpqa": "tsx src/cli.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "qa",
    "validation",
    "testing"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@hono/node-server": "^1.19.12",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@types/better-sqlite3": "^7.6.13",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "hono": "^4.12.10",
    "openai": "^6.33.0",
    "ora": "^8.2.0",
    "uuid": "^11.1.0",
    "yaml": "^2.7.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "@types/uuid": "^10.0.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
